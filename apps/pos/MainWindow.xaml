<Window x:Class="pos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:pos.Utils"
        Title="MirhaPret POS System"
        Height="640"
        Width="1100"
        Background="#f5f5f5"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:CountToVisibilityConverter  x:Key="CountToVisibilityConverter"/>
        <local:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Height="50" VerticalAlignment="Top" Background="#000000">
            <Grid Margin="20,0">
                <TextBlock Text="MirhaPret POS"
                           Foreground="#ffffff" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="👤 " Foreground="#aaaaaa" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CashierName}" Foreground="#ffffff" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── TabControl ──────────────────────────────────────────────────── -->
        <TabControl Margin="0,50,0,0" Background="#f5f5f5" BorderThickness="0"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="#f5f5f5"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </TabControl.Resources>

            <!-- ════════════════ TAB 1: NEW SALE ════════════════ -->
            <TabItem Header="New Sale">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: search + cart -->
                    <StackPanel Grid.Column="0" Margin="20">
                        <!-- Loading indicator -->
                        <TextBlock Text="⟳ Loading products from server..."
                                   FontSize="12" Foreground="#888888" Margin="0,0,0,8"
                                   Visibility="{Binding IsLoadingProducts, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#c0392b" FontSize="11"
                                   Margin="0,0,0,8" TextWrapping="Wrap"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                        <!-- Search/Barcode Input -->
                        <TextBlock Text="Scan or Search Product" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Padding="10,10"
                                         FontSize="14"
                                         Background="#ffffff"
                                         BorderBrush="#e0e0e0"
                                         BorderThickness="1"
                                         Margin="0,0,8,0"
                                         Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Margin="0,0,8,0"
                                        Visibility="{Binding SearchSuggestions.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                    <ListBox ItemsSource="{Binding SearchSuggestions}"
                                             Background="#ffffff" BorderThickness="0" MaxHeight="150" Padding="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.SelectProductCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"/>
                                                        <TextBlock FontSize="10" Foreground="#666666">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}  |  PKR {1:N0}">
                                                                    <Binding Path="Barcode"/>
                                                                    <Binding Path="Price"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Add"
                                    Background="#000000" Foreground="#ffffff"
                                    FontSize="12" FontWeight="Bold" Cursor="Hand"
                                    Padding="20,10" Command="{Binding AddToCartCommand}"/>
                        </Grid>

                        <!-- Cart Items -->
                        <TextBlock Text="Cart Items" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Padding="12" Height="350" VerticalAlignment="Top">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CartItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#f5f5f5" Padding="10" Margin="0,0,0,8" BorderBrush="#e0e0e0" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="50" Height="50" Background="#e0e0e0" BorderBrush="#999999" BorderThickness="1" Margin="0,0,10,0">
                                                        <TextBlock Text="IMG" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#666666" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="12"/>
                                                        <TextBlock FontSize="10" Foreground="#666666" Margin="0,4,0,0">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} | PKR {1:N0}">
                                                                    <Binding Path="Barcode"/>
                                                                    <Binding Path="UnitPrice"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">
                                                        <Button Content="-" Background="#ffffff" BorderBrush="#000000" BorderThickness="1" Width="20" Height="20" FontSize="10" Padding="0"
                                                                Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DecreaseQuantityCommand}" CommandParameter="{Binding}"/>
                                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" HorizontalAlignment="Center" Width="20" TextAlignment="Center" FontWeight="Bold"/>
                                                        <Button Content="+" Background="#ffffff" BorderBrush="#000000" BorderThickness="1" Width="20" Height="20" FontSize="10" Padding="0"
                                                                Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IncreaseQuantityCommand}" CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="3" Content="Remove" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" FontSize="10" Padding="8,4"
                                                            Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RemoveFromCartCommand}" CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Right: Order Summary -->
                    <Border Grid.Column="1" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Margin="0,20,20,20" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Order Summary" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Subtotal:" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat='PKR {0:N0}'}" FontSize="12" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Tax (17%):" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxAmount, StringFormat='PKR {0:N0}'}" FontSize="12" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Discount:" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding DiscountAmount, StringFormat='PKR {0:N0}'}" FontSize="12" FontWeight="Bold"/>
                            </Grid>

                            <Border Height="1" Background="#e0e0e0" Margin="0,8,0,8"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Total:" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat='PKR {0:N0}'}" FontSize="14" FontWeight="Bold"/>
                            </Grid>

                            <!-- Promo Code -->
                            <TextBlock Text="Promo Code" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Padding="8,6" FontSize="11" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Margin="0,0,6,0"
                                         Text="{Binding PromoCode, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="Apply" Background="#000000" Foreground="#ffffff" FontSize="10" FontWeight="Bold"
                                        Command="{Binding ApplyPromoCommand}"/>
                            </Grid>

                            <!-- Complete Sale -->
                            <Button Content="Complete Sale"
                                    Background="#000000" Foreground="#ffffff"
                                    FontSize="12" FontWeight="Bold"
                                    Padding="0,12" Cursor="Hand"
                                    Command="{Binding CompleteSaleCommand}"/>

                            <!-- Clear Cart -->
                            <Button Content="Clear Cart"
                                    Background="#ffffff" Foreground="#000000"
                                    BorderBrush="#000000" BorderThickness="1"
                                    FontSize="11" Padding="0,8" Margin="0,8,0,0" Cursor="Hand"
                                    Command="{Binding ClearCartCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════ TAB 2: ORDERS ════════════════ -->
            <TabItem Header="Today's Orders">
                <Grid Margin="20">
                    <!-- Stats row -->
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Padding="16,10" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Total Orders" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding OrderCount}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" Padding="16,10" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Revenue (POS)" FontSize="11" Foreground="#666666"/>
                                <TextBlock Text="{Binding OrdersRevenue, StringFormat='PKR {0:N0}'}" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="3" Content="⟳  Refresh"
                                Background="#000000" Foreground="#ffffff"
                                FontSize="11" FontWeight="Bold" Padding="16,10"
                                Cursor="Hand" VerticalAlignment="Center"
                                Command="{Binding RefreshOrdersCommand}"/>
                    </Grid>

                    <!-- Loading -->
                    <TextBlock Text="Loading orders..." FontSize="12" Foreground="#888888"
                               Margin="0,60,0,0" HorizontalAlignment="Center"
                               Visibility="{Binding IsLoadingOrders, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Orders DataGrid -->
                    <DataGrid Margin="0,60,0,0"
                              ItemsSource="{Binding TodaysOrders}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="#ffffff"
                              BorderBrush="#e0e0e0"
                              BorderThickness="1"
                              RowBackground="#ffffff"
                              AlternatingRowBackground="#f9f9f9"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"         Binding="{Binding FormattedTime}"  Width="80"/>
                            <DataGridTextColumn Header="Order #"      Binding="{Binding OrderNumber}"    Width="160"/>
                            <DataGridTextColumn Header="Customer"     Binding="{Binding CustomerName}"   Width="*"/>
                            <DataGridTextColumn Header="Phone"        Binding="{Binding CustomerPhone}"  Width="130"/>
                            <DataGridTextColumn Header="Status"       Binding="{Binding Status}"         Width="90"/>
                            <DataGridTextColumn Header="Total"        Binding="{Binding FormattedTotal}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
