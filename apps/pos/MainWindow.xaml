<Window x:Class="pos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:pos.Utils"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        Title="MirhaPret POS System"
        Icon="Resources/logo-favicon.png"
        Height="700"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#f5f4f0"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:CountToVisibilityConverter  x:Key="CountToVisibilityConverter"/>
        <local:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>

        <!-- ── TabControl Template (custom nav bar style) ──────── -->
        <Style x:Key="PosTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="22,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="0,0,0,2.5"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              TextBlock.FontSize="13"
                                              TextBlock.FontWeight="SemiBold"
                                              TextBlock.FontFamily="Segoe UI"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#c8a96e"/>
                                <Setter Property="Foreground" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#f5f0e8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Qty button style -->
        <Style x:Key="QtyBtn" TargetType="Button">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#eae8e3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#f5f0e8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#c8a96e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#eae0d0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header style -->
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontFamily="{TemplateBinding FontFamily}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid row style -->
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#eae8e3"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#faf7f0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#f5f0e8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell style -->
        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ══ HEADER ══════════════════════════════════════════════ -->
        <Border Height="60" VerticalAlignment="Top" Background="#111111">
            <Grid Margin="24,0">
                <!-- Brand left -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <svgc:SvgViewbox Source="pack://application:,,,/Resources/logo-icon-white.svg"
                                     Width="44" Height="44" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Point of Sale" Foreground="#c8a96e" FontSize="11" FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cashier right -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="#1e1e1e" CornerRadius="20" Padding="14,7"
                        BorderBrush="#2a2a2a" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="12" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#c8a96e" Offset="0"/>
                                    <GradientStop Color="#a8894e" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="C" Foreground="#111111" FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="{Binding CashierName}" Foreground="#dddddd"
                                   FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ TAB CONTROL ═════════════════════════════════════════ -->
        <TabControl Margin="0,60,0,0" Background="#f5f4f0" BorderThickness="0" Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Tab nav strip -->
                        <Border Grid.Row="0" Background="#ffffff" BorderBrush="#eae8e3" BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True" Background="Transparent" Margin="10,0"/>
                        </Border>
                        <!-- Content -->
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ════════════ TAB 1: NEW SALE ════════════════════════ -->
            <TabItem Header="New Sale" Style="{StaticResource PosTabItem}">
                <Grid Background="#f5f4f0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Left: Search + Cart ───────────────────── -->
                    <Grid Grid.Column="0" Margin="20,20,12,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Loading -->
                        <Border Grid.Row="0" Background="#faf7f0" CornerRadius="7" Padding="12,8" Margin="0,0,0,10"
                                BorderBrush="#e8dfc8" BorderThickness="1"
                                Visibility="{Binding IsLoadingProducts, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⟳ " Foreground="#c8a96e" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Loading products from server..." Foreground="#a8894e"
                                           FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Error -->
                        <Border Grid.Row="1" Background="#fff0ee" CornerRadius="7" Padding="12,8" Margin="0,0,0,10"
                                BorderBrush="#c0392b" BorderThickness="1"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#c0392b"
                                       FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Category filter strip -->
                        <Border Grid.Row="2" Background="#ffffff" CornerRadius="10"
                                BorderBrush="#eae8e3" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal">
                                    <!-- "All" button -->
                                    <Button Content="All"
                                            Command="{Binding FilterByCategoryCommand}"
                                            CommandParameter="{x:Null}"
                                            Margin="0,0,6,0" Padding="14,6" Cursor="Hand"
                                            FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#111111"/>
                                                <Setter Property="Foreground" Value="#ffffff"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- Dynamic category buttons -->
                                    <ItemsControl ItemsSource="{Binding Categories}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}"
                                                        Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.FilterByCategoryCommand}"
                                                        CommandParameter="{Binding Id}"
                                                        Margin="0,0,6,0" Padding="14,6" Cursor="Hand"
                                                        FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#f5f4f0"/>
                                                            <Setter Property="Foreground" Value="#555555"/>
                                                            <Setter Property="BorderBrush" Value="#eae8e3"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#f5f0e8"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#c8a96e"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Search section -->
                        <Border Grid.Row="3" Background="#ffffff" CornerRadius="10"
                                BorderBrush="#eae8e3" BorderThickness="1" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="SCAN OR SEARCH" Foreground="#888888"
                                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                                           Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBox Padding="12,10"
                                                 FontSize="13"
                                                 FontFamily="Segoe UI"
                                                 Background="#f9f8f6"
                                                 BorderBrush="#eae8e3"
                                                 BorderThickness="1"
                                                 Margin="0,0,8,0"
                                                 Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.Template>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#c8a96e"/>
                                                            <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </TextBox.Template>
                                        </TextBox>
                                        <!-- Suggestions dropdown -->
                                        <Border Background="#ffffff" CornerRadius="7"
                                                BorderBrush="#eae8e3" BorderThickness="1" Margin="0,4,8,0"
                                                Visibility="{Binding SearchSuggestions.Count, Converter={StaticResource CountToVisibilityConverter}}">
                                            <ListBox ItemsSource="{Binding SearchSuggestions}"
                                                     Background="Transparent" BorderThickness="0"
                                                     MaxHeight="180" Padding="4">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#faf7f0"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.SelectProductCommand}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Padding="10,9" HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left" Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                               FontSize="12" FontFamily="Segoe UI" Foreground="#111111"/>
                                                                    <TextBlock FontSize="11" Foreground="#888888"
                                                                               FontFamily="Segoe UI" Margin="0,2,0,0">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="{}{0}">
                                                                                <Binding Path="Barcode"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" FontSize="12"
                                                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                                                           Foreground="#c8a96e" VerticalAlignment="Center">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="PKR {0:N0}">
                                                                            <Binding Path="Price"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </StackPanel>
                                    <!-- Add button -->
                                    <Button Grid.Column="1" Content="+ Add"
                                            Style="{StaticResource ButtonGold}"
                                            FontSize="13" FontWeight="Bold"
                                            Padding="20,10"
                                            Command="{Binding AddToCartCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Cart Items -->
                        <Border Grid.Row="4" Background="#ffffff" CornerRadius="10"
                                BorderBrush="#eae8e3" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Cart header -->
                                <Border Grid.Row="0" Padding="16,12" BorderBrush="#eae8e3" BorderThickness="0,0,0,1">
                                    <TextBlock Text="CART ITEMS" Foreground="#888888"
                                               FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                </Border>
                                <!-- Cart list -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                                    <ItemsControl ItemsSource="{Binding CartItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#faf9f7" CornerRadius="8"
                                                        Padding="12" Margin="0,0,0,8"
                                                        BorderBrush="#eae8e3" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Product avatar (image or gradient fallback) -->
                                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                                                Margin="0,0,12,0" ClipToBounds="True">
                                                            <Grid>
                                                                <!-- Gradient fallback -->
                                                                <Border CornerRadius="8">
                                                                    <Border.Background>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#c8a96e" Offset="0"/>
                                                                            <GradientStop Color="#a8894e" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Border.Background>
                                                                    <TextBlock Text="P" Foreground="#ffffff"
                                                                               FontSize="16" FontWeight="Bold"
                                                                               FontFamily="Segoe UI"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"
                                                                               Visibility="{Binding ImageUrl, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=invert}"/>
                                                                </Border>
                                                                <!-- Product image (shown when ImageUrl is set) -->
                                                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                                                       Visibility="{Binding ImageUrl, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Product info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProductName}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       FontFamily="Segoe UI" Foreground="#111111"/>
                                                            <TextBlock FontSize="11" Foreground="#888888"
                                                                       FontFamily="Segoe UI" Margin="0,3,0,0">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0}  ·  PKR {1:N0}">
                                                                        <Binding Path="Barcode"/>
                                                                        <Binding Path="UnitPrice"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- Qty controls -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                    VerticalAlignment="Center" Margin="12,0,12,0">
                                                            <Button Content="−" Style="{StaticResource QtyBtn}"
                                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.DecreaseQuantityCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Border Background="#ffffff" CornerRadius="5" Margin="4,0"
                                                                    Padding="6,0" BorderBrush="#eae8e3" BorderThickness="1"
                                                                    MinWidth="32" Height="26">
                                                                <TextBlock Text="{Binding Quantity}"
                                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                           TextAlignment="Center"
                                                                           FontWeight="Bold" FontSize="12"
                                                                           FontFamily="Segoe UI" Foreground="#111111"/>
                                                            </Border>
                                                            <Button Content="+" Style="{StaticResource QtyBtn}"
                                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.IncreaseQuantityCommand}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>

                                                        <!-- Remove -->
                                                        <Button Grid.Column="3" Content="✕"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="#cccccc" FontSize="14" Padding="6,4"
                                                                VerticalAlignment="Center" Cursor="Hand"
                                                                Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RemoveFromCartCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Right: Order Summary ──────────────────── -->
                    <Border Grid.Column="1" Background="#ffffff" CornerRadius="10"
                            BorderBrush="#eae8e3" BorderThickness="1" Margin="0,20,20,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Summary header -->
                            <Border Grid.Row="0" Padding="20,16" BorderBrush="#eae8e3" BorderThickness="0,0,0,1">
                                <TextBlock Text="ORDER SUMMARY" Foreground="#888888"
                                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                            </Border>

                            <!-- Line items -->
                            <StackPanel Grid.Row="1" Margin="20,16,20,0">
                                <!-- Subtotal -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Subtotal" Foreground="#666666" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="#111111">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="PKR {0:N0}">
                                                <Binding Path="Subtotal"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <!-- Tax -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Tax (17%)" Foreground="#666666" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="#111111">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="PKR {0:N0}">
                                                <Binding Path="TaxAmount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <!-- Discount -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Discount" Foreground="#666666" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="#1a7a4a">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="- PKR {0:N0}">
                                                <Binding Path="DiscountAmount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <!-- Total divider -->
                                <Border Height="1" Background="#eae8e3" Margin="0,0,0,14"/>

                                <!-- Total -->
                                <Border Background="#f5f0e8" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TOTAL" Foreground="#a8894e" FontSize="12"
                                                   FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" FontSize="18" FontWeight="Bold"
                                                   FontFamily="Segoe UI" Foreground="#111111">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="PKR {0:N0}">
                                                    <Binding Path="Total"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- Promo Code -->
                                <TextBlock Text="PROMO CODE" Foreground="#888888"
                                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Padding="10,9" FontSize="12"
                                             FontFamily="Segoe UI" Background="#f9f8f6"
                                             BorderBrush="#eae8e3" BorderThickness="1" Margin="0,0,7,0"
                                             Text="{Binding PromoCode, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="7">
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#c8a96e"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                    <Button Grid.Column="1" Content="Apply"
                                            Style="{StaticResource ButtonSecondary}"
                                            FontSize="11" FontWeight="SemiBold"
                                            Padding="12,9"
                                            Command="{Binding ApplyPromoCommand}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="2" Margin="20,16,20,20">
                                <Button Content="Complete Sale"
                                        Style="{StaticResource ButtonGold}"
                                        FontSize="14" FontWeight="Bold"
                                        Padding="0,14"
                                        Command="{Binding CompleteSaleCommand}"/>
                                <Button Content="Clear Cart"
                                        Style="{StaticResource ButtonSecondary}"
                                        FontSize="12" Padding="0,10" Margin="0,8,0,0"
                                        Command="{Binding ClearCartCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 2: TODAY'S ORDERS ══════════════════ -->
            <TabItem Header="Today's Orders" Style="{StaticResource PosTabItem}">
                <Grid Background="#f5f4f0" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Stats row -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Orders card -->
                        <Border Grid.Column="0" Background="#ffffff" CornerRadius="10"
                                BorderBrush="#eae8e3" BorderThickness="1" Padding="20,14" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#eae8e3" BlurRadius="8" ShadowDepth="1" Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="TODAY'S ORDERS" Foreground="#888888"
                                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding OrderCount}" Foreground="#111111"
                                           FontSize="26" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- Revenue card -->
                        <Border Grid.Column="1" Background="#ffffff" CornerRadius="10"
                                BorderBrush="#eae8e3" BorderThickness="1" Padding="20,14" Margin="0,0,12,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#eae8e3" BlurRadius="8" ShadowDepth="1" Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="REVENUE (POS)" Foreground="#888888"
                                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Foreground="#1a7a4a">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="PKR {0:N0}">
                                            <Binding Path="OrdersRevenue"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Refresh button -->
                        <Button Grid.Column="3" Content="⟳  Refresh"
                                Style="{StaticResource ButtonPrimary}"
                                FontSize="12" FontWeight="SemiBold"
                                Padding="18,12" VerticalAlignment="Center"
                                Command="{Binding RefreshOrdersCommand}"/>
                    </Grid>

                    <!-- Loading -->
                    <Border Grid.Row="1"
                            Visibility="{Binding IsLoadingOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Loading orders..." Foreground="#888888"
                                   FontSize="13" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </Border>

                    <!-- Orders table -->
                    <Border Grid.Row="2" CornerRadius="10" BorderBrush="#eae8e3" BorderThickness="1"
                            Background="#ffffff" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding TodaysOrders}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Background="#ffffff"
                                  BorderThickness="0"
                                  RowBackground="#ffffff"
                                  AlternatingRowBackground="#faf9f7"
                                  FontSize="13"
                                  FontFamily="Segoe UI"
                                  SelectionMode="Single"
                                  HorizontalGridLinesBrush="#eae8e3"
                                  VerticalGridLinesBrush="Transparent"
                                  ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                                  RowStyle="{StaticResource DgRowStyle}"
                                  CellStyle="{StaticResource DgCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"     Binding="{Binding FormattedTime}"  Width="80"/>
                                <DataGridTextColumn Header="Order #"  Binding="{Binding OrderNumber}"    Width="150"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}"   Width="*"/>
                                <DataGridTextColumn Header="Phone"    Binding="{Binding CustomerPhone}"  Width="120"/>
                                <DataGridTextColumn Header="Status"   Binding="{Binding Status}"         Width="90"/>
                                <DataGridTextColumn Header="Total"    Binding="{Binding FormattedTotal}" Width="110"/>
                                <DataGridTemplateColumn Header="Action" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Refund"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RefundOrderCommand}"
                                                    CommandParameter="{Binding}"
                                                    Margin="4,3" Padding="10,4"
                                                    FontSize="11" FontWeight="SemiBold"
                                                    FontFamily="Segoe UI" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#fff0ee"/>
                                                        <Setter Property="Foreground" Value="#c0392b"/>
                                                        <Setter Property="BorderBrush" Value="#fdd"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#ffe0de"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
