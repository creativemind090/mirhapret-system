<Window x:Class="pos.Views.CheckoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:pos.Utils"
        Title="Complete Sale"
        Height="350"
        Width="400"
        Background="#f5f5f5"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:PhoneBorderConverter x:Key="PhoneBorderConverter"/>
    </Window.Resources>
    
    <Border BorderBrush="#000000" BorderThickness="1">
        <StackPanel Background="#ffffff">
            <!-- Header -->
            <Border Background="#000000" Padding="16,12">
                <TextBlock Text="Customer Information" 
                           Foreground="#ffffff" 
                           FontSize="14"
                           FontWeight="Bold"/>
            </Border>

            <!-- Content -->
            <Border Padding="20">
                <StackPanel>
                    <!-- Customer Name -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Customer Name" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Padding="10,10" 
                                 FontSize="12"
                                 Background="#ffffff"
                                 BorderBrush="#e0e0e0"
                                 BorderThickness="1"
                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Customer Phone -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Mobile Number" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Padding="10,10" 
                                 FontSize="12"
                                 Background="#ffffff"
                                 BorderBrush="{Binding IsPhoneValid, Converter={StaticResource PhoneBorderConverter}}"
                                 BorderThickness="1"
                                 Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding PhoneError}" 
                                   Foreground="#c0392b" 
                                   FontSize="10" 
                                   Margin="0,4,0,0"
                                   Visibility="{Binding PhoneError, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Payment Method -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Payment Method" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <WrapPanel Orientation="Horizontal">
                            <RadioButton Content="Cash"
                                         IsChecked="{Binding IsCash}"
                                         GroupName="PaymentMethod"
                                         FontSize="12" Margin="0,0,16,4"/>
                            <RadioButton Content="Card"
                                         IsChecked="{Binding IsCard}"
                                         GroupName="PaymentMethod"
                                         FontSize="12" Margin="0,0,0,4"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Buttons -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" 
                                Content="Cancel" 
                                Background="#ffffff" 
                                Foreground="#000000"
                                BorderBrush="#000000"
                                BorderThickness="1"
                                FontSize="12"
                                FontWeight="Bold"
                                Padding="0,10"
                                Cursor="Hand"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" 
                                Content="Print Sale" 
                                Background="#000000" 
                                Foreground="#ffffff"
                                FontSize="12"
                                FontWeight="Bold"
                                Padding="0,10"
                                Cursor="Hand"
                                Command="{Binding PrintCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
