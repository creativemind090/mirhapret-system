<Window x:Class="pos.Views.SizeSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Size"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="#f5f5f5">
    <Border BorderBrush="#000000" BorderThickness="1">
        <StackPanel Background="#ffffff">
            <!-- Header -->
            <Border Background="#000000" Padding="16,12">
                <TextBlock x:Name="HeaderText"
                           Foreground="#ffffff" FontSize="13" FontWeight="Bold"/>
            </Border>

            <!-- Size buttons -->
            <StackPanel Margin="20,16,20,8">
                <TextBlock Text="Select Size:" FontSize="12" FontWeight="Bold" Margin="0,0,0,12"/>
                <WrapPanel x:Name="SizePanel" Orientation="Horizontal"/>
            </StackPanel>

            <!-- Cancel -->
            <Border Padding="20,8,20,16">
                <Button Content="Cancel"
                        Background="#ffffff" Foreground="#000000"
                        BorderBrush="#000000" BorderThickness="1"
                        FontSize="12" FontWeight="Bold"
                        Padding="0,8" Cursor="Hand"
                        Click="Cancel_Click"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
