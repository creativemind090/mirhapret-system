# Environment Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ecommerce_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-for-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long-for-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP (PrivateEmail / Namecheap)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=contact@mirhapret.com
SMTP_PASS=your_smtp_password

# Site URL (used in email links)
SITE_URL=https://mirhapret.com

# Application
APP_NAME=Mirhapret E-commerce Platform
APP_VERSION=1.0.0
